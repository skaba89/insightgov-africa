# ============================================
# INSIGHTGOV AFRICA - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# DATABASE
# ============================================
# For SQLite (development):
DATABASE_URL=file:./db/insightgov.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/insightgov?schema=public

# ============================================
# NEXTAUTH.JS (Authentication)
# ============================================
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-change-in-production
NEXTAUTH_URL=http://localhost:3000

# ============================================
# AI PROVIDER
# ============================================
# Options: z-ai-sdk (default, free), groq, openai
AI_PROVIDER=z-ai-sdk
AI_MODEL=glm-4-plus

# Optional: Groq API key (free at https://console.groq.com)
# GROQ_API_KEY=gsk_your_api_key

# Optional: OpenAI API key
# OPENAI_API_KEY=sk-your_api_key

# ============================================
# APPLICATION
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=InsightGov Africa

# ============================================
# OPTIONAL SERVICES
# ============================================
# Paystack (payments for Africa)
# PAYSTACK_SECRET_KEY=sk_test_xxx
# PAYSTACK_PUBLIC_KEY=pk_test_xxx

# Sentry (error monitoring)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# Email (Resend)
# RESEND_API_KEY=re_xxx

# ============================================
# DOCKER (for docker-compose)
# ============================================
DB_PASSWORD=insightgov123
