# =============================================================================
# InsightGov Africa - Environment Configuration
# =============================================================================

# =============================================================================
# DATABASE (Required)
# =============================================================================
# SQLite for local development
DATABASE_URL="file:./dev.db"

# PostgreSQL for production (CockroachDB, Supabase, etc.)
# DATABASE_URL="postgresql://user:password@host:5432/insightgov?schema=public"

# =============================================================================
# AUTHENTICATION (Required)
# =============================================================================
NEXTAUTH_SECRET="votre-secret-minimum-32-caracteres-ici-changez-moi!"
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# AI PROVIDER (Required for AI features)
# =============================================================================
# Options: "openai" or "groq"
AI_PROVIDER="groq"

# Groq API (Recommended - Free tier available)
GROQ_API_KEY="votre-cle-api-groq"

# OpenAI API (Alternative)
# OPENAI_API_KEY="sk-your-openai-api-key"

# =============================================================================
# SMS NOTIFICATIONS (Africa's Talking - RECOMMENDED - FREE SANDBOX)
# =============================================================================
# Provider: africas_talking (default), twilio, orange, nexmo
SMS_PROVIDER="africas_talking"

# Africa's Talking Configuration
# Get your free API key at: https://africastalking.com
# 
# FREE SANDBOX MODE (for development):
# - Create account at https://africastalking.com
# - Go to Sandbox App
# - Use username: "sandbox" and your sandbox API key
# - Test SMS will appear in your dashboard (not sent to real phones)
#
AFRICAS_TALKING_USERNAME="sandbox"
AFRICAS_TALKING_API_KEY="votre-api-key-sandbox-africas-talking"
AFRICAS_TALKING_SENDER_ID="InsightGov"

# =============================================================================
# ALTERNATIVE SMS PROVIDERS
# =============================================================================

# Twilio (Paid - $15.50 free credit on signup)
# SMS_PROVIDER="twilio"
# TWILIO_ACCOUNT_SID="your-account-sid"
# TWILIO_AUTH_TOKEN="your-auth-token"
# TWILIO_PHONE_NUMBER="+1234567890"

# Orange SMS API (Africa)
# SMS_PROVIDER="orange"
# ORANGE_API_KEY="your-orange-api-key"
# ORANGE_CLIENT_ID="your-client-id"
# ORANGE_SENDER_ID="InsightGov"

# Vonage/Nexmo
# SMS_PROVIDER="nexmo"
# NEXMO_API_KEY="your-api-key"
# NEXMO_API_SECRET="your-api-secret"
# NEXMO_SENDER_ID="InsightGov"

# =============================================================================
# PAYMENTS - Stripe (Gratuit en mode test)
# =============================================================================
# Stripe Test Mode (gratuit pour le développement)
# Créez un compte sur https://stripe.com et obtenez vos clés de test
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
STRIPE_MODE="test"

# Price IDs (à créer dans le dashboard Stripe)
# STRIPE_PRICE_STARTER="price_xxx"
# STRIPE_PRICE_PROFESSIONAL="price_xxx"
# STRIPE_PRICE_ENTERPRISE="price_xxx"

# =============================================================================
# PAIEMENTS MOBILE MONEY (À configurer plus tard)
# =============================================================================
# Orange Money Guinea
# ORANGE_MONEY_API_KEY=""
# ORANGE_MONEY_API_SECRET=""
# ORANGE_MONEY_MERCHANT_CODE=""
# ORANGE_MONEY_WEBHOOK_SECRET=""
# ORANGE_MONEY_ENVIRONMENT="sandbox"

# MTN Money Guinea
# MTN_MONEY_API_KEY=""
# MTN_MONEY_API_SECRET=""
# MTN_MONEY_MERCHANT_CODE=""
# MTN_MONEY_WEBHOOK_SECRET=""
# MTN_MONEY_ENVIRONMENT="sandbox"

# =============================================================================
# MONITORING - Sentry (Gratuit - 5K événements/mois)
# =============================================================================
# Créez un compte sur https://sentry.io et obtenez votre DSN
SENTRY_DSN="https://a1b2c3d4e5f6@o1234567.ingest.sentry.io/1234567"
NEXT_PUBLIC_SENTRY_DSN="https://a1b2c3d4e5f6@o1234567.ingest.sentry.io/1234567"
SENTRY_ENVIRONMENT="development"
# SENTRY_RELEASE="1.0.0"

# Redis for caching and rate limiting (production)
# REDIS_URL="redis://localhost:6379"

# =============================================================================
# EMAIL (Optional)
# =============================================================================
# Resend for transactional emails
# RESEND_API_KEY="re_your-resend-api-key"

# SMTP Configuration (Alternative)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your-smtp-user"
# SMTP_PASSWORD="your-smtp-password"

# =============================================================================
# BACKUP STORAGE (Optional)
# =============================================================================
# AWS S3 for backup storage
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_S3_BUCKET="insightgov-backups"
# AWS_REGION="eu-west-1"

# =============================================================================
# FEATURES FLAGS
# =============================================================================
# Enable/disable features
ENABLE_SMS_NOTIFICATIONS="true"
ENABLE_EMAIL_NOTIFICATIONS="false"
ENABLE_BACKUP_SCHEDULER="true"

# =============================================================================
# RENDER DEPLOYMENT (Auto-configured)
# =============================================================================
# Render automatically sets these:
# - PORT (default: 3000)
# - NODE_ENV=production
# - RENDER_SERVICE_ID
# - RENDER_SERVICE_NAME
# - RENDER_SERVICE_TYPE

# =============================================================================
# ADMIN SETUP (For initial seed)
# =============================================================================
# Used for creating the first admin user during deployment
# ADMIN_EMAIL="admin@yourdomain.com"
# ADMIN_PASSWORD="secure-admin-password"
# ADMIN_NAME="Admin User"
