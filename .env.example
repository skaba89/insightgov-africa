# ============================================
# INSIGHTGOV AFRICA - Configuration
# ============================================
# Copiez ce fichier en .env et remplissez les valeurs
# cp .env.example .env

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# Docker (local development)
DATABASE_URL=postgresql://insightgov:insightgov123@postgres:5432/insightgov?schema=public

# Ou pour une connexion locale (hors Docker):
# DATABASE_URL=postgresql://insightgov:insightgov123@localhost:5432/insightgov?schema=public

# Neon (cloud - gratuit)
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# Railway (cloud - gratuit)
# DATABASE_URL=postgresql://user:password@host.railway.app/railway

# ============================================
# NEXTAUTH.JS (Authentification)
# ============================================
# Génerez une clé secrète: openssl rand -base64 32
NEXTAUTH_SECRET=local_dev_secret_change_in_production_12345
NEXTAUTH_URL=http://localhost:3000

# En production:
# NEXTAUTH_URL=https://votre-domaine.com

# ============================================
# PROVIDER IA (groq ou openai)
# ============================================
AI_PROVIDER=groq

# ============================================
# GROQ AI (Recommandé - Gratuit/Pas cher)
# ============================================
# Créez une clé API sur: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Modèles Groq disponibles:
# - llama-3.3-70b-versatile (recommandé)
# - llama-3.1-8b-instant (rapide)
# - mixtral-8x7b-32768
AI_MODEL=llama-3.3-70b-versatile

# ============================================
# OPENAI (Alternative - Payant)
# ============================================
# Si vous préférez OpenAI, changez AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4o

# ============================================
# PAYSTACK (Paiements - Afrique)
# ============================================
# Obtenez ces valeurs sur: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_...

# ============================================
# APPLICATION
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=InsightGov Africa

# ============================================
# OPTIONNEL
# ============================================
# Taille max des fichiers (10MB par défaut)
MAX_FILE_SIZE=10485760

# Mode démo (désactive les appels API réels)
# DEMO_MODE=true
