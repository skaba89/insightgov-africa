# =============================================================================
# InsightGov Africa - Development Dockerfile
# =============================================================================
# Image optimisée pour le développement avec:
# - Hot reload pour les modifications de code
# - Prisma intégré avec génération automatique
# - Support ARM64 et AMD64
# - Outils de développement inclus
# =============================================================================

FROM node:20-alpine

WORKDIR /app

# =============================================================================
# DÉPENDANCES SYSTÈME
# =============================================================================

# Installer les outils nécessaires au développement
# - openssl: requis pour Prisma
# - curl: pour les health checks
# - bash: pour les scripts
# - git: pour les opérations git
# - dos2unix: conversion des fins de ligne
RUN apk add --no-cache \
    openssl \
    curl \
    bash \
    git \
    dos2unix \
    libc6-compat \
    && rm -rf /var/cache/apk/*

# =============================================================================
# CONFIGURATION DE L'UTILISATEUR
# =============================================================================

# Créer un utilisateur non-root (optionnel en développement)
# Commenté pour simplifier le développement
# RUN addgroup -S appgroup && adduser -S appuser -G appgroup

# =============================================================================
# VARIABLES D'ENVIRONNEMENT
# =============================================================================

ENV NODE_ENV=development
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
ENV NEXT_TELEMETRY_DISABLED=1
ENV WATCHPACK_POLLING=true

# =============================================================================
# INSTALLATION DES DÉPENDANCES
# =============================================================================

# Copier les fichiers de dépendances
COPY package.json package-lock.json* ./

# Copier Prisma avant npm install (nécessaire pour postinstall)
COPY prisma ./prisma/

# Installer les dépendances
# --legacy-peer-deps: pour la compatibilité React 19
RUN npm install --legacy-peer-deps && \
    npm cache clean --force

# Générer le client Prisma
RUN npx prisma generate

# =============================================================================
# COPIE DU CODE SOURCE
# =============================================================================

# Copier tout le code source
# En mode développement, les volumes peuvent surcharger ces fichiers
COPY . .

# =============================================================================
# SCRIPTS DE DÉMARRAGE
# =============================================================================

# Copier et préparer le script de démarrage
COPY docker-start-local.sh /app/start-dev.sh
RUN dos2unix /app/start-dev.sh && chmod +x /app/start-dev.sh

# =============================================================================
# RÉSEAU
# =============================================================================

# Exposer le port de développement
EXPOSE 3000

# =============================================================================
# HEALTH CHECK
# =============================================================================

# Health check pour le développement
# Plus tolérant que la production
HEALTHCHECK --interval=30s --timeout=15s --start-period=60s --retries=5 \
    CMD curl -f http://localhost:3000/api/health || exit 1

# =============================================================================
# POINT D'ENTRÉE
# =============================================================================

# Utiliser le script de démarrage local
CMD ["/bin/bash", "/app/start-dev.sh"]
