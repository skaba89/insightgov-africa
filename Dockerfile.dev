# =============================================================================
# InsightGov Africa - Development Dockerfile
# =============================================================================
# Using Node.js for better Prisma compatibility
# =============================================================================

FROM node:20-alpine

WORKDIR /app

# Install system dependencies (OpenSSL required for Prisma)
RUN apk add --no-cache \
    openssl \
    libc6-compat \
    curl \
    bash \
    dos2unix

# Copy package files first
COPY package.json ./

# Copy prisma schema before install
COPY prisma ./prisma/

# Install dependencies with npm (legacy-peer-deps for React 19 compatibility)
RUN npm install --legacy-peer-deps

# Generate Prisma client
RUN npx prisma generate

# Copy source code
COPY . .

# Copy startup script and convert line endings
COPY docker-start.sh /app/start.sh
RUN dos2unix /app/start.sh && chmod +x /app/start.sh

# Expose port
EXPOSE 3000

# Set environment
ENV NODE_ENV=development
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:3000/api/health || exit 1

# Start with initialization script
CMD ["/bin/bash", "/app/start.sh"]
