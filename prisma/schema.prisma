// =============================================================================
// InsightGov Africa - Prisma Schema
// =============================================================================
// Plateforme SaaS de génération de dashboards automatisés pour Ministères, ONG et Entreprises
// Base de données SQLite pour le développement local (PostgreSQL pour la production)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// NEXTAUTH.JS MODELS
// =============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================================
// ORGANISATIONS
// =============================================================================

/// Organisation cliente (Ministère, ONG, Entreprise)
model Organization {
  id              String   @id @default(cuid())
  name            String
  type            String   // 'ministry' | 'ngo' | 'enterprise'
  sector          String   // 'health' | 'education' | 'agriculture' | ...
  subscriptionTier String  @default("free") // 'free' | 'starter' | 'professional' | 'enterprise'
  logoUrl         String?
  country         String?
  city            String?
  phone           String?
  website         String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  users           User[]
  datasets        Dataset[]
  subscriptions   Subscription[]

  @@index([type])
  @@index([sector])
  @@index([subscriptionTier])
}

// =============================================================================
// UTILISATEURS
// =============================================================================

/// Utilisateur de la plateforme
model User {
  id                       String    @id @default(cuid())
  email                    String    @unique
  emailVerified            DateTime?
  firstName                String?
  lastName                 String?
  password                 String?   // Hashed password for credentials auth
  avatarUrl                String?
  organizationId           String?
  role                     String    @default("viewer") // 'owner' | 'admin' | 'analyst' | 'viewer'
  isActive                 Boolean   @default(true)
  lastLoginAt              DateTime?
  verificationToken        String?   // For email verification
  verificationTokenExpiry  DateTime? // Expiry for verification token
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  // Relations
  organization      Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  accounts          Account[]
  sessions          Session[]
  datasets          Dataset[]
  kpiConfigs        KPIConfig[]
  reportExports     ReportExport[]
  comments          Comment[]
  notifications     Notification[]
  activityLogs      ActivityLog[]

  @@index([email])
  @@index([organizationId])
}

// =============================================================================
// DATASETS (FICHIERS UPLOADÉS)
// =============================================================================

/// Fichier de données uploadé par l'utilisateur
model Dataset {
  id               String   @id @default(cuid())
  organizationId   String?
  userId           String
  name             String
  originalFileName String
  fileUrl          String
  fileSize         Int      // en bytes
  fileType         String   // 'csv' | 'xlsx' | 'xls'
  rowCount         Int      @default(0)
  columnCount      Int      @default(0)
  columnsMetadata  String   @default("[]") // JSON: ColumnMetadata[]
  status           String   @default("pending") // 'uploading' | 'pending' | 'analyzing' | 'ready' | 'error'
  errorMessage     String?
  analyzedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  organization     Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  kpiConfigs       KPIConfig[]

  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// =============================================================================
// CONFIGURATIONS KPI
// =============================================================================

/// Configuration KPI générée par l'IA
model KPIConfig {
  id            String   @id @default(cuid())
  datasetId     String
  userId        String
  version       Int      @default(1)
  configJson    String   // JSON: DashboardConfig
  isPublished   Boolean  @default(false)
  generatedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  dataset       Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([datasetId])
  @@index([userId])
  @@index([isPublished])
}

// =============================================================================
// ABONNEMENTS
// =============================================================================

/// Abonnement et facturation
model Subscription {
  id               String    @id @default(cuid())
  organizationId   String
  tier             String    // 'free' | 'starter' | 'professional' | 'enterprise'
  status           String    @default("active") // 'active' | 'canceled' | 'expired' | 'past_due'
  price            Float     @default(0)
  currency         String    @default("EUR")
  billingCycle     String    @default("monthly") // 'monthly' | 'yearly'
  currentPeriodEnd DateTime?
  cancelAtPeriodEnd Boolean  @default(false)
  paystackCustomerId   String?
  paystackSubscriptionId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
}

// =============================================================================
// EXPORTS & RAPPORTS
// =============================================================================

/// Historique des exports de rapports
model ReportExport {
  id           String    @id @default(cuid())
  datasetId    String
  userId       String
  format       String    // 'pdf' | 'excel' | 'image'
  fileUrl      String?
  status       String    @default("pending") // 'pending' | 'processing' | 'completed' | 'error'
  errorMessage String?
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([datasetId])
  @@index([userId])
  @@index([createdAt])
}

// =============================================================================
// COLLABORATION & PARTAGE
// =============================================================================

/// Invitation d'un membre à une organisation
model TeamInvitation {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           String    @default("viewer") // 'admin' | 'analyst' | 'viewer'
  token          String    @unique
  invitedBy      String    // userId
  expiresAt      DateTime
  acceptedAt     DateTime?
  status         String    @default("pending") // 'pending' | 'accepted' | 'expired' | 'canceled'
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@index([email])
  @@index([token])
  @@index([status])
}

/// Partage d'un dataset avec d'autres utilisateurs
model DatasetShare {
  id           String    @id @default(cuid())
  datasetId    String
  sharedBy     String    // userId
  sharedWith   String?   // userId (null si public)
  permission   String    @default("view") // 'view' | 'edit' | 'admin'
  expiresAt    DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([datasetId])
  @@index([sharedBy])
  @@index([sharedWith])
}

/// Commentaire sur un dataset ou KPI
model Comment {
  id          String    @id @default(cuid())
  datasetId   String?
  kpiId       String?   // KPIConfig id
  userId      String
  parentId    String?   // Pour les réponses
  content     String
  mentions    String?   // JSON array d'userIds mentionnés
  isResolved  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[] @relation("CommentReplies")

  @@index([datasetId])
  @@index([kpiId])
  @@index([userId])
  @@index([createdAt])
}

/// Notification utilisateur
model Notification {
  id           String    @id @default(cuid())
  userId       String
  type         String    // 'comment' | 'share' | 'mention' | 'export' | 'alert'
  title        String
  message      String
  data         String?   // JSON payload
  isRead       Boolean   @default(false)
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

/// Activité/Audit log
model ActivityLog {
  id             String    @id @default(cuid())
  organizationId String?
  userId         String?
  action         String    // 'upload' | 'analyze' | 'export' | 'share' | 'comment' | 'delete'
  entityType     String    // 'dataset' | 'kpi' | 'user' | 'organization'
  entityId       String?
  metadata       String?   // JSON payload
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime  @default(now())

  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// =============================================================================
// API ACCESS & WEBHOOKS
// =============================================================================

/// Clé API pour intégrations
model ApiKey {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  keyHash        String    @unique  // Hash de la clé API
  keyPrefix      String             // Préfixe visible (ex: "iga_xxxx")
  permissions    String    @default("read") // JSON: ['read', 'write', 'admin']
  rateLimit      Int       @default(1000) // Requêtes par heure
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdBy      String    // userId
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@index([keyPrefix])
  @@index([isActive])
}

/// Webhook pour notifications externes
model Webhook {
  id              String     @id @default(cuid())
  organizationId  String
  name            String
  url             String
  secret          String?    // Secret pour signature HMAC
  events          String     // JSON: ['dataset.created', 'analysis.completed', ...]
  isActive        Boolean    @default(true)
  lastTriggeredAt DateTime?
  failureCount    Int        @default(0)
  createdBy       String     // userId
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([organizationId])
  @@index([isActive])
}

/// Historique des appels webhook
model WebhookDelivery {
  id           String    @id @default(cuid())
  webhookId    String
  event        String
  payload      String    // JSON payload envoyé
  responseCode Int?
  responseBody String?
  success      Boolean   @default(false)
  duration     Int?      // Durée en ms
  error        String?
  createdAt    DateTime  @default(now())

  @@index([webhookId])
  @@index([createdAt])
}

// =============================================================================
// KPI & DASHBOARD TEMPLATES
// =============================================================================

/// Template de KPI prédéfini par secteur
model KPITemplate {
  id                  String   @id @default(cuid())
  sector              String
  category            String
  code                String   @unique
  name                String
  nameFr              String
  description         String?
  formula             String
  unit                String
  format              String   @default("number")
  decimals            Int      @default(0)
  target              Float?
  targetSource        String?
  lowerIsBetter       Boolean  @default(false)
  sdgAlignment        String?
  dataSource          String?
  frequency           String   @default("monthly")
  disaggregation      String   @default("[]")
  alertThresholds     String   @default("{}")
  visualizationType   String?
  visualizationColors String?
  requiredColumns     String?
  dimensions          String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([sector])
  @@index([category])
  @@index([code])
  @@index([isActive])
}

/// Template de dashboard prédéfini
model DashboardTemplate {
  id              String   @id @default(cuid())
  sector          String
  category        String?
  code            String   @unique
  name            String
  nameFr          String
  description     String?
  widgets         String   @default("[]")
  filters         String   @default("[]")
  alerts          String   @default("[]")
  icon            String?
  tags            String   @default("[]")
  recommendedFor  String   @default("[]")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  widgetTemplates WidgetTemplate[]

  @@index([sector])
  @@index([code])
  @@index([isActive])
}

/// Template de widget pour dashboard
model WidgetTemplate {
  id                  String           @id @default(cuid())
  dashboardTemplateId String
  x                   Int              @default(0)
  y                   Int              @default(0)
  width               Int              @default(4)
  height              Int              @default(3)
  type                String
  title               String
  titleFr             String?
  kpiTemplateCode     String?
  config              String           @default("{}")
  displayOrder        Int              @default(0)

  dashboardTemplate   DashboardTemplate @relation(fields: [dashboardTemplateId], references: [id], onDelete: Cascade)

  @@index([dashboardTemplateId])
  @@index([kpiTemplateCode])
}
