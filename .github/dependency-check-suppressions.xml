<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
  
  <!-- Example: Suppress false positive for Next.js -->
  <!-- <suppress>
    <notes><![CDATA[
      Explain why this vulnerability is suppressed (e.g., not applicable, false positive, etc.)
    ]]></notes>
    <packageUrl regex="true">^pkg:npm/next@.*$</packageUrl>
    <cve>CVE-XXXX-XXXX</cve>
  </suppress> -->
  
  <!-- Suppress development dependency vulnerabilities -->
  <suppress>
    <notes><![CDATA[
      Dev dependencies are not shipped in production builds.
    ]]></notes>
    <packageUrl regex="true">^pkg:npm/@tailwindcss/.*$</packageUrl>
    <cpe>cpe:/a:tailwindlabs:tailwind_css</cpe>
  </suppress>
  
  <!-- Accept risk for Prisma dev dependency -->
  <suppress>
    <notes><![CDATA[
      Prisma is used for database migrations and client generation in development.
      The runtime client has no known critical vulnerabilities.
    ]]></notes>
    <packageUrl regex="true">^pkg:npm/prisma@.*$</packageUrl>
    <vulnerabilityName>CVE-2024-23724</vulnerabilityName>
  </suppress>

</suppressions>
