# =============================================================================
# InsightGov Africa - Docker Ignore
# =============================================================================
# Fichiers et répertoires à exclure du contexte de build Docker
# Cela réduit la taille de l'image et accélère le build
# =============================================================================

# =============================================================================
# DÉPENDANCES
# =============================================================================
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
# NOTE: bun.lock est nécessaire pour bun install --frozen-lockfile
# package-lock.json

# =============================================================================
# BUILD OUTPUT
# =============================================================================
.next
out
build
dist
.turbo

# =============================================================================
# FICHIERS DE DÉVELOPPEMENT
# =============================================================================
.git
.gitignore
.gitattributes
.github

# IDE et éditeurs
.idea
.vscode
*.swp
*.swo
*~
.project
.classpath
.c9
*.launch
.settings

# =============================================================================
# ENVIRONNEMENT ET SECRETS
# =============================================================================
.env
.env.*
!.env.example
.env.local
.env.development
.env.test
.env.production

# =============================================================================
# TESTS
# =============================================================================
coverage
.nyc_output
*.lcov
__tests__
__mocks__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
e2e
playwright-report
test-results
src/tests

# =============================================================================
# DOCUMENTATION
# =============================================================================
docs
*.md
!README.md
CHANGELOG.md
CONTRIBUTING.md
LICENSE
SECURITY.md

# =============================================================================
# FICHIERS DE CONFIGURATION (non nécessaires en production)
# =============================================================================
docker-compose*.yml
Dockerfile*
.docker
.dockerignore
Makefile
.editorconfig
.eslintrc*
.eslintignore
.prettierrc*
.prettierignore
.stylelintrc*
jest.config.*
vitest.config.*
playwright.config.*
sentry.*.config.*
vercel.json
render.yaml
Caddyfile

# NOTE: Les fichiers de configuration suivants sont NÉCESSAIRES pour le build
# et ne doivent PAS être exclus:
# - tsconfig.json (TypeScript)
# - next.config.ts (Next.js)
# - tailwind.config.ts (Tailwind CSS)
# - postcss.config.mjs (PostCSS)
# - components.json (shadcn/ui)

# =============================================================================
# FICHIERS TEMPORAIRES ET LOGS
# =============================================================================
*.log
logs
*.pid
*.seed
*.pid.lock
.npm
.yarn-integrity
.yarn

# =============================================================================
# FICHIERS UPLOADÉS ET DONNÉES
# =============================================================================
uploads
upload
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.ico
*.webp

# =============================================================================
# BASES DE DONNÉES LOCALES
# =============================================================================
*.db
*.db-journal
*.sqlite
*.sqlite3
prisma/*.db
prisma/*.db-journal

# =============================================================================
# FICHIERS DE SAUVEGARDE
# =============================================================================
backups
*.backup
*.bak
*.sql.gz

# =============================================================================
# FICHIERS DE DÉPLOIEMENT
# =============================================================================
scripts
kubernetes
helm
.terraform
terraform
ansible

# =============================================================================
# AUTRES FICHIERS NON NÉCESSAIRES
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.pem
*.key
*.crt

# =============================================================================
# FICHIERS DE CACHE
# =============================================================================
.cache
.parcel-cache
.eslintcache
.stylelintcache
*.tsbuildinfo
